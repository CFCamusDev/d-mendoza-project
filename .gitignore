# ==========================================
# NODE
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js
package-lock.json.backup

# ==========================================
# BUILD OUTPUTS
# ==========================================
dist/
build/
out/

# ==========================================
# TYPESCRIPT
# ==========================================
*.tsbuildinfo

# ==========================================
# VITE
# ==========================================
client/.vite/
client/dist/

# ==========================================
# PRISMA
# ==========================================
# No ignorar schema.prisma ni migrations/
# Solo ignorar el cliente generado si está fuera de node_modules
server/src/generated/

# ==========================================
# ENVIRONMENT VARIABLES
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example NO se ignora (es la plantilla para el equipo)

# ==========================================
# DOCKER
# ==========================================
# No ignorar docker-compose.yml ni Dockerfiles
# Solo ignorar overrides locales
docker-compose.override.yml
docker-compose.local.yml

# ==========================================
# LOGS
# ==========================================
logs/
*.log

# ==========================================
# TESTING
# ==========================================
coverage/
.nyc_output/

# ==========================================
# EDITORS & IDEs
# ==========================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# OPERATING SYSTEM
# ==========================================
.DS_Store
Thumbs.db
Desktop.ini
