# ========================================
# DATABASE (MariaDB)
# ========================================
DB_ROOT_PASSWORD=rootpassword
DB_DATABASE=dmendoza_db
DB_USER=dmendoza_user
DB_PASSWORD=dmendoza_pass

# ========================================
# SERVER (Backend)
# ========================================
# NODE_ENV indica el entorno de ejecución (ej. development, production, test)
NODE_ENV=development
SERVER_PORT=3000
BCRYPT_SALT_ROUNDS=12
RESEND_API_KEY=re_1234567890_placeholder
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here

# ========================================
# CLIENT (Frontend)
# ========================================
CLIENT_PORT=5173
VITE_API_URL=http://localhost:3000/api
