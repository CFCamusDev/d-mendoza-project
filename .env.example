# ========================================
# DATABASE (MariaDB)
# ========================================
DB_ROOT_PASSWORD=rootpassword
DB_DATABASE=dmendoza_db
DB_USER=dmendoza_user
DB_PASSWORD=dmendoza_pass

# ========================================
# SERVER (Backend)
# ========================================
# NODE_ENV indica el entorno de ejecución (ej. development, production, test)
NODE_ENV=development
SERVER_PORT=3000
BCRYPT_SALT_ROUNDS=12
RESEND_API_KEY=re_1234567890_placeholder
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
SEED_ADMIN_EMAIL=admin_seed@domain.com
SEED_ADMIN_PASSWORD=set_your_own_secure_password_here
# RSK-003 / T-046: Comma-separated IPv4/IPv6 addresses allowed to reach admin routes.
# Leave empty to allow all IPs (development mode). Example: 10.0.0.1,192.168.1.100
IP_WHITELIST=

# ========================================
# GOOGLE OAuth 2.0
# ========================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback


# ========================================
# CLIENT (Frontend)
# ========================================
CLIENT_PORT=5173
VITE_API_URL=http://localhost:3000/api
