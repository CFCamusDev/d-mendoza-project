{
  "name": "geo-peru",
  "version": "1.1.0",
  "description": "Peru ubigeo data from RENIEC — departments, provinces, and districts",
  "keywords": [
    "peru",
    "ubigeo",
    "departments",
    "provinces",
    "districts",
    "reniec",
    "geodir"
  ],
  "author": "kedeinroga",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
