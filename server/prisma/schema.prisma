// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String?
  password  String
  googleId      String?    @unique
  avatarUrl     String?
  lastName      String?
  phone         String?
  authProvider  String     @default("local") // "local" | "google"
  lastLogin       DateTime?
  isActive        Boolean    @default(false)
  verificationPin String?
  pinExpiresAt    DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  auditLogs       AuditLog[]
  roles           Role[] // RBAC many-to-many relationship (HU-004)
  employee        Employee?
  client          Client?
}

model Client {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String
  phone      String?
  documentId String?  @unique // DNI/RUC
  userId     Int?     @unique
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  dni       String   @unique
  isActive  Boolean  @default(true)
  userId    Int?     @unique
  user      User?    @relation(fields: [userId], references: [id])
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  address   String?
  phone     String?
  isActive  Boolean    @default(true)
  employees Employee[]
  warehouse Warehouse?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Warehouse {
  id        Int      @id @default(autoincrement())
  branchId  Int      @unique
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique // e.g., "ADMIN", "SELLER", "CLIENT"
  description String?
  users       User[]
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g., "users:write", "products:read"
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String // Ejemplo: "LOGIN", "CREATE_USER"
  module    String // Ejemplo: "AUTH", "USERS"
  details   Json? // Para guardar datos de la acción
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// HU-014: Gestión de Variantes SKU (T-076)
// HU-015: Inactivación Lógica de Productos
// ─────────────────────────────────────────────

model Product {
  id          Int              @id @default(autoincrement())
  code        String           @unique // Código base para auto-generación de SKU (ej. "CAM")
  name        String
  description String?
  categoryId  Int?
  isActive    Boolean          @default(true)
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductVariant {
  id             Int      @id @default(autoincrement())
  productId      Int
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // SKU único auto-generado: código_producto-talla-color (ej. "CAM-M-NEGRO")
  sku            String   @unique
  price          Decimal  @db.Decimal(10, 2)
  // JSON con los atributos de la variante: { "talla": "M", "color": "NEGRO" }
  attributesJson Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productId])
}

model BrandConfig {
  id              Int      @id @default(1)
  brandName       String   @default("D'Mendoza")
  logoUrl         String?
  primaryColor    String   @default("#4F46E5")
  socialLinksJson Json?
  updatedAt       DateTime @updatedAt
}

// ─── HU-011 ───────────────────────────────────────────────────────────────────

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryChildren")
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Brand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── HU-012 ───────────────────────────────────────────────────────────────────

model Attribute {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  isActive  Boolean          @default(true)
  values    AttributeValue[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model AttributeValue {
  id          Int       @id @default(autoincrement())
  value       String
  isActive    Boolean   @default(true)
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([attributeId, value])
}
