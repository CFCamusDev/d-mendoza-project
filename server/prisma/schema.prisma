// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int        @id @default(autoincrement())
  email           String     @unique
  name            String?
  password        String
  googleId        String?    @unique
  avatarUrl       String?
  lastName        String?
  phone           String?
  authProvider    String     @default("local") // "local" | "google"
  lastLogin       DateTime?
  isActive        Boolean    @default(false)
  mustChangePassword Boolean   @default(false)
  verificationPin String?
  pinExpiresAt    DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  auditLogs       AuditLog[]
  roles           Role[] // RBAC many-to-many relationship (HU-004)
  employee        Employee?
  client          Client?
  cashTurns       CashTurn[] // HU-032
  wishlists       Wishlist[] // HU-010
  carts           Cart[]     // HU-041
  addresses       Address[]
  blogPosts       BlogPost[]
  coupons         Coupon[]
  orders          Order[]
}

model Client {
  id           Int      @id @default(autoincrement())
  email        String?  @unique
  name         String   // Nombres o Razón Social
  lastName     String?  // Apellidos
  phone        String?
  documentType String?  // DNI o RUC
  documentId   String?  @unique // DNI/RUC número
  address      String?
  department   String?
  province     String?
  district     String?
  ubigeo       String?
  userId       Int?     @unique
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  dni       String   @unique
  isActive  Boolean  @default(true)
  userId    Int?     @unique
  user      User?    @relation(fields: [userId], references: [id])
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  address         String?
  phone           String?
  isActive        Boolean          @default(true)
  isMain          Boolean          @default(false)
  employees       Employee[]
  branchStock     BranchStock[]
  kardexEntries   KardexEntry[]
  stockEntries    StockEntry[]     // HU-051
  warehouse       Warehouse?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  stockAlerts     StockAlert[]
  inventoryAudits InventoryAudit[] // HU-029
  posOrders       PosOrder[]       // HU-034
  cashRegisters   CashRegister[]   // HU-032
  transfersSent     StockTransfer[]  @relation("TransfersSent")
  transfersReceived StockTransfer[]  @relation("TransfersReceived")
  sourcePosOrders   PosOrder[]       @relation("SourceBranchOrders")
}

model Warehouse {
  id        Int      @id @default(autoincrement())
  branchId  Int      @unique
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique // e.g., "ADMIN", "SELLER", "CLIENT"
  description String?
  users       User[]
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g., "users:write", "products:read"
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String // Ejemplo: "LOGIN", "CREATE_USER"
  module    String // Ejemplo: "AUTH", "USERS"
  details   Json? // Para guardar datos de la acción
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// HU-014: Gestión de Variantes SKU (T-076)
// HU-015: Inactivación Lógica de Productos
// ─────────────────────────────────────────────

model BrandConfig {
  id                Int      @id @default(1)
  brandName         String   @default("D'Mendoza")
  faviconUrl        String?
  logoHorizontalUrl String?
  logoVerticalUrl   String?
  colorBrandBg      String   @default("#F7F7F5")
  colorBrandPrimary String   @default("#D9D9D2")
  colorBrandText    String   @default("#6B6B6B")
  colorBrandAccent  String   @default("#3F3F3F")
  socialLinksJson   Json?
  updatedAt         DateTime @updatedAt
}

// ─────────────────────────────────────────────
// HU-019: Gestión de Banners y Sliders (T-083)
// ─────────────────────────────────────────────
model Banner {
  id        Int      @id @default(autoincrement())
  imageUrl  String   @db.Text
  linkUrl   String?  @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── HU-011 ───────────────────────────────────────────────────────────────────

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryChildren")
  isActive     Boolean    @default(true)
  sizeGuideUrl String?
  products     Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  logoUrl   String?
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── HU-012 ───────────────────────────────────────────────────────────────────

model Attribute {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  isActive  Boolean          @default(true)
  values    AttributeValue[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model AttributeValue {
  id          Int       @id @default(autoincrement())
  value       String
  isActive    Boolean   @default(true)
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([attributeId, value])
}

// ─── HU-013 ───────────────────────────────────────────────────────────────────

model Product {
  id          Int              @id @default(autoincrement())
  code        String           @unique // Código base para auto-generación de SKU (ej. "CAM")
  name        String
  slug        String           @unique
  description String?          @db.Text
  categoryId  Int?
  category    Category?        @relation(fields: [categoryId], references: [id])
  brandId     Int?
  brand       Brand?           @relation(fields: [brandId], references: [id])
  gender      String?
  isActive    Boolean          @default(true)
  images      ProductImage[]
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  url       String
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── HU-026 (dependencies: ProductVariant + BranchStock) ─────────────────────

model ProductVariant {
  id              Int              @id @default(autoincrement())
  productId       Int
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku             String           @unique // SKU único auto-generado: código_producto-talla-color
  price           Decimal          @default(0) @db.Decimal(10, 2)
  discountPercent Int              @default(0) // HU-017
  attributesJson  Json? // JSON con los atributos de la variante
  isActive        Boolean          @default(true)
  minStock        Int              @default(5)
  branchStock     BranchStock[]
  kardexEntries   KardexEntry[]
  stockEntryItems StockEntryItem[] // HU-051
  stockAlerts     StockAlert[]
  auditItems      AuditItem[]      // HU-029
  posOrderItems   PosOrderItem[]   // HU-034
  wishlists       Wishlist[]       // HU-010
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  stockTransfers  StockTransfer[]
  cartItems       CartItem[]       // HU-041
  orderItems      OrderItem[]

  @@index([productId])
}

model BranchStock {
  id        Int            @id @default(autoincrement())
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  branchId  Int
  branch    Branch         @relation(fields: [branchId], references: [id])
  quantity  Float          @default(0)
  status    StockStatus    @default(AVAILABLE)
  updatedAt DateTime       @updatedAt

  @@unique([variantId, branchId, status])
}

// ─── HU-026 ───────────────────────────────────────────────────────────────────

enum KardexType {
  ENTRADA
  SALIDA
  AJUSTE
}

model KardexEntry {
  id          Int            @id @default(autoincrement())
  variantId   Int
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  branchId    Int
  branch      Branch         @relation(fields: [branchId], references: [id])
  type        KardexType
  quantity    Float
  unitCost    Float
  balanceQty  Float
  balanceCost Float
  createdAt   DateTime       @default(now())
}

// ─── HU-051: Gestión de Proveedores y Registro de Ingreso de Mercadería ─────────

model Supplier {
  id           Int          @id @default(autoincrement())
  ruc          String       @unique
  razonSocial  String
  contacto     String
  direccion    String?
  isActive     Boolean      @default(true)
  stockEntries StockEntry[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model StockEntry {
  id            Int              @id @default(autoincrement())
  supplierId    Int
  supplier      Supplier         @relation(fields: [supplierId], references: [id])
  invoiceNumber String
  branchId      Int
  branch        Branch           @relation(fields: [branchId], references: [id])
  items         StockEntryItem[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([supplierId])
  @@index([branchId])
}

model StockEntryItem {
  id           Int            @id @default(autoincrement())
  stockEntryId Int
  stockEntry   StockEntry     @relation(fields: [stockEntryId], references: [id], onDelete: Cascade)
  variantId    Int
  variant      ProductVariant @relation(fields: [variantId], references: [id])
  quantity     Float
  unitCost     Float

  @@index([stockEntryId])
  @@index([variantId])
}

// ─── HU-027: Alertas de Stock Crítico ─────────────────────────────────────────

model StockAlert {
  id        Int            @id @default(autoincrement())
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  branchId  Int
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  isActive  Boolean        @default(true) // Turns false when stock is replenished or manually dismissed
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([variantId, branchId])
}

// ─── HU-029: Auditoría de Inventario Físico (Toma de Inventario) ──────────────

enum AuditStatus {
  PENDING
  CONFIRMED
}

model InventoryAudit {
  id        Int         @id @default(autoincrement())
  branchId  Int
  branch    Branch      @relation(fields: [branchId], references: [id])
  status    AuditStatus @default(PENDING)
  items     AuditItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([branchId])
}

model AuditItem {
  id          Int            @id @default(autoincrement())
  auditId     Int
  audit       InventoryAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  variantId   Int
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  physicalQty Float
  systemQty   Float
  difference  Float

  @@index([auditId])
  @@index([variantId])
}

// ─── HU-034: Aplicación de Descuentos en el POS ───────────────────────────────
// ─── HU-035: Pago con Múltiples Métodos Combinados ────────────────────────────

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  YAPE
}

enum PosOrderStatus {
  OPEN
  COMPLETED
  CANCELLED
}

/// Cabecera de una venta en el Punto de Venta (POS).
model PosOrder {
  id            Int            @id @default(autoincrement())
  status        PosOrderStatus @default(OPEN)
  subtotal      Decimal        @default(0) @db.Decimal(10, 2)
  discountTotal Decimal        @default(0) @db.Decimal(10, 2) // Suma de todos los descuentos aplicados
  total         Decimal        @default(0) @db.Decimal(10, 2)
  userId        Int? // Cajero que abrió la venta
  branchId      Int
  branch        Branch         @relation(fields: [branchId], references: [id])
  isCrossBranch Boolean        @default(false)
  sourceBranchId Int?
  sourceBranch  Branch?        @relation("SourceBranchOrders", fields: [sourceBranchId], references: [id])
  items         PosOrderItem[]
  payments      Payment[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([branchId])
  @@index([userId])
  @@index([sourceBranchId])
}

/// Ítem de línea dentro de una venta POS.
/// T-124: Se agrega el campo discountAmount (Decimal, default 0).
model PosOrderItem {
  id             Int            @id @default(autoincrement())
  posOrderId     Int
  posOrder       PosOrder       @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
  variantId      Int
  variant        ProductVariant @relation(fields: [variantId], references: [id])
  quantity       Int            @default(1)
  unitPrice      Decimal        @db.Decimal(10, 2)
  discountAmount Decimal        @default(0) @db.Decimal(10, 2) // T-124: Descuento aplicado al ítem (monto fijo)
  lineTotal      Decimal        @db.Decimal(10, 2) // (unitPrice * quantity) - discountAmount

  @@index([posOrderId])
  @@index([variantId])
}

/// Pagos asociados a una venta POS.
model Payment {
  id         Int          @id @default(autoincrement())
  posOrderId Int
  posOrder   PosOrder     @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
  method     PaymentMethod
  amount     Decimal      @db.Decimal(10, 2)
  createdAt  DateTime     @default(now())

  @@index([posOrderId])
}

// ─── HU-032: Apertura de Caja y Vinculación al Turno del Vendedor ─────────────

enum TurnStatus {
  OPEN
  CLOSED
}

model CashRegister {
  id        Int        @id @default(autoincrement())
  branchId  Int
  branch    Branch     @relation(fields: [branchId], references: [id])
  name      String
  isActive  Boolean    @default(true)
  cashTurns CashTurn[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([branchId])
}

model CashTurn {
  id          Int            @id @default(autoincrement())
  registerId  Int
  register    CashRegister   @relation(fields: [registerId], references: [id])
  userId      Int
  user        User           @relation(fields: [userId], references: [id])
  openAmount  Float
  closeAmount Float?         // HU-037: Monto físico declarado al cerrar
  status      TurnStatus     @default(OPEN)
  openedAt    DateTime       @default(now())
  closedAt    DateTime?
  movements   CashMovement[] // HU-037: Movimientos de caja
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([registerId])
  @@index([userId])
}

// ─── HU-010: Lista de Favoritos del Cliente (Wishlist) ─────────────────────────

model Wishlist {
  id        Int            @id @default(autoincrement())
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  addedAt   DateTime       @default(now())

  @@unique([userId, variantId])
  @@index([userId])
  @@index([variantId])
}

// ─── HU-037: Movimientos de Caja y Cierre de Turno ────────────────────────────

enum CashMovementType {
  INGRESO
  EGRESO
}

model CashMovement {
  id        Int              @id @default(autoincrement())
  turnId    Int
  turn      CashTurn         @relation(fields: [turnId], references: [id])
  type      CashMovementType
  amount    Float
  reason    String
  createdAt DateTime         @default(now())

  @@index([turnId])
}

enum TransferStatus {
  PENDING
  CONFIRMED
}

enum StockStatus {
  AVAILABLE
  RESERVED
  SOLD
}

model StockTransfer {
  id           Int            @id @default(autoincrement())
  fromBranchId Int
  fromBranch   Branch         @relation("TransfersSent", fields: [fromBranchId], references: [id])
  toBranchId   Int
  toBranch     Branch         @relation("TransfersReceived", fields: [toBranchId], references: [id])
  variantId    Int
  variant      ProductVariant @relation(fields: [variantId], references: [id])
  quantity     Float
  status       TransferStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([variantId])
}

// ─── HU-041: Carrito de Compras Persistente ───────────────────────────────────

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int?
  user      User?      @relation(fields: [userId], references: [id])
  sessionId String?    @unique // Para carritos anónimos
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
  @@index([sessionId])
}

model CartItem {
  id        Int            @id @default(autoincrement())
  cartId    Int
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int            @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([cartId, variantId])
}

model Address {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  alias       String   // Ej: "Casa", "Trabajo"
  fullAddress String   @db.Text
  district    String
  reference   String?  @db.Text
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id              Int        @id @default(autoincrement())
  title           String
  slug            String     @unique
  content         String     @db.Text
  status          PostStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  views           Int        @default(0)
  authorId        Int
  author          User       @relation(fields: [authorId], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([authorId])
}

// ─── HU-054: Configuración de Zonas de Delivery ───────────────────────────────

model DeliveryZone {
  id            Int      @id @default(autoincrement())
  districts     Json     // Almacenado como JSON en MySQL para guardar arreglo de strings
  deliveryCost  Decimal  @db.Decimal(10, 2)
  estimatedDays Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum CouponType {
  PERCENT
  FIXED
}

model Coupon {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  type        CouponType
  value       Decimal   @db.Decimal(10, 2)
  expiresAt   DateTime?
  maxUses     Int?
  usedCount   Int       @default(0)
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int
  user            User        @relation(fields: [userId], references: [id])
  status          OrderStatus @default(PENDING)
  total           Decimal     @db.Decimal(10, 2)
  shippingCost    Decimal     @db.Decimal(10, 2)
  addressSnapshot Json
  paymentIntentId String      @unique
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
}

model OrderItem {
  id        Int            @id @default(autoincrement())
  orderId   Int
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  qty       Int
  unitPrice Decimal        @db.Decimal(10, 2)

  @@index([orderId])
  @@index([variantId])
}
