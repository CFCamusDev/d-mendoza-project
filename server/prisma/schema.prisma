// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String?
  password  String
  googleId      String?    @unique
  avatarUrl     String?
  lastName      String?
  phone         String?
  authProvider  String     @default("local") // "local" | "google"
  lastLogin       DateTime?
  isActive        Boolean    @default(false)
  verificationPin String?
  pinExpiresAt    DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  auditLogs       AuditLog[]
  roles           Role[] // RBAC many-to-many relationship (HU-004)
  employee        Employee?
  client          Client?
}

model Client {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String
  phone      String?
  documentId String?  @unique // DNI/RUC
  userId     Int?     @unique
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  dni       String   @unique
  isActive  Boolean  @default(true)
  userId    Int?     @unique
  user      User?    @relation(fields: [userId], references: [id])
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  address   String?
  phone     String?
  isActive  Boolean    @default(true)
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique // e.g., "ADMIN", "SELLER", "CLIENT"
  description String?
  users       User[]
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g., "users:write", "products:read"
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String // Ejemplo: "LOGIN", "CREATE_USER"
  module    String // Ejemplo: "AUTH", "USERS"
  details   Json? // Para guardar datos de la acción
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
